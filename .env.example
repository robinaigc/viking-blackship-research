# Optional privacy-friendly analytics token.
NEXT_PUBLIC_BEAM_TOKEN=

# Required for working subscriptions. The endpoint must accept a JSON POST
# with email, source, and subscribedAt fields.
SUBSCRIBE_WEBHOOK_URL=

# Optional bearer token sent to the subscription webhook.
SUBSCRIBE_WEBHOOK_SECRET=

# Supabase article publishing backend.
NEXT_PUBLIC_APP_URL=https://vikingblackship.com
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Only this normalized email address may access /admin.
ADMIN_EMAIL=
